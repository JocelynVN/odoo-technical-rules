# pylint config that runs Odoo's REAL test_lint checks, using Odoo's own
# checker plugins (the ones in odoo/addons/test_lint/tests). This is exactly
# what Odoo's test_pylint.py runs — same plugins, same enabled messages — so
# you get Odoo's authentic SQL-injection / gettext / unlink-override checks,
# not a reimplementation.
#
# HOW TO RUN — use the Python interpreter of YOUR Odoo env, so that `odoo` is
# importable and Odoo's own checkers load automatically. The npx installer saves
# it to .odoo-lint.json ("python" field); otherwise ask the user, then:
#
#     "<python>" -m pylint --rcfile=pylintrc path/to/your_module
#
# (Install pylint into that interpreter once if missing: "<python>" -m pip
# install "pylint>=3.0". Odoo does NOT ship pylint in requirements.txt and its
# own test skips when it's absent, so this one-time install is expected.)
#
# The init-hook below then finds Odoo's checker modules next to the importable
# `odoo` package and adds them to sys.path so load-plugins can import them by
# name — the same mechanism test_pylint.py uses.
#
# If Odoo runs from a SOURCE checkout that isn't pip-installed (so `import odoo`
# fails even there), export the Odoo root explicitly — the dir that contains the
# `odoo/` package — and the init-hook will use it:
#     ODOO_PATH=/path/to/odoo "<python>" -m pylint --rcfile=pylintrc path/to/your_module
#
# Pure-pip alternative (no Odoo source needed): `"<python>" -m pip install
# pylint-odoo` and replace the three _odoo_checker_* plugins below with `pylint_odoo`.

[MAIN]
# Make Odoo's own checker modules importable (mirrors test_pylint.py). Prefer an
# explicit ODOO_PATH override; otherwise locate them next to the importable
# `odoo` package. No-op if neither is found.
init-hook=
    import os, sys
    _root = os.environ.get("ODOO_PATH")
    try:
        if _root:
            sys.path.insert(0, os.path.join(_root, "odoo", "addons", "test_lint", "tests"))
        else:
            import odoo
            sys.path.insert(0, os.path.join(os.path.dirname(odoo.__file__), "addons", "test_lint", "tests"))
    except Exception:
        pass

# bad_builtin is a stock pylint extension; the _odoo_checker_* are Odoo's own.
load-plugins=
    pylint.extensions.bad_builtin,
    _odoo_checker_sql_injection,
    _odoo_checker_gettext,
    _odoo_checker_unlink_override

[MESSAGES CONTROL]
# Exactly the set test_pylint.py enables.
disable=all
enable=
    used-before-assignment,
    undefined-variable,
    eval-used,
    unreachable,
    function-redefined,
    bad-builtin,
    deprecated-module,
    sql-injection,
    gettext-variable,
    gettext-placeholders,
    gettext-repr,
    raise-unlink-override

[DEPRECATED_BUILTINS]
bad-functions=input

[IMPORTS]
# csv/urllib/cgi + Odoo's SUPPORTED_DEBUGGER (pdb, ipdb, pudb, q).
deprecated-modules=csv,urllib,cgi,pdb,ipdb,pudb,q

[REPORTS]
reports=no
score=no
msg-template={path}:{line}: [{msg_id}] {symbol}: {msg}
